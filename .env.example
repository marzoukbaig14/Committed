# Required environment variables for this project.
# In GitHub Codespaces, these are injected automatically from repo secrets
# (Settings → Secrets and variables → Codespaces).
# For local dev outside Codespaces, copy this file to .env and fill values.

HF_TOKEN=
WANDB_API_KEY=
GEMINI_API_KEY=

# --- Serving (all optional; safe defaults in committed.inference.engine) ---
# Explicit local GGUF path. Set this to swap in the fine-tuned model (one-line swap).
COMMITTED_MODEL_PATH=
# Or pull from the Hub (public; no token). Defaults to the pinned baseline (ADR 0038).
COMMITTED_MODEL_REPO=
COMMITTED_MODEL_FILE=
# Tokenizer source for the chat template (defaults to Qwen/Qwen3-1.7B).
COMMITTED_TOKENIZER=
# Comma-separated exact CORS origins (prod + custom domain). *.vercel.app is allowed by regex.
COMMITTED_CORS_ORIGINS=
